# ─────────────────────────────────────────────────────────────
# World News & Topic Summary Agent — Backend Environment
# ─────────────────────────────────────────────────────────────

# ── Google Gemini (LLM) ──────────────────────────────────────
# If left as a placeholder, the app falls back to built-in mock data.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_NAME=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ── Langfuse (Observability, optional) ───────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── News Provider ────────────────────────────────────────────
# Primary: NewsData.io   (https://newsdata.io/)
# Fallback/alternative: CurrentsAPI (https://currentsapi.services/en)
NEWSDATA_API_KEY=your-newsdata-api-key
CURRENTS_API_KEY=your-currentsapi-key
# Which provider to prefer: "newsdata" or "currents"
NEWS_PROVIDER=newsdata

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
